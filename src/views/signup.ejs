<%- include('partials/header') %>

<div class="auth-page">
    <div class="auth-box">
        <div class="auth-box-top">
            <h2>Create an account</h2>
            <p>Join the developer community</p>
        </div>
        
        <div class="auth-box-body">
            <div id="signup-msg" class="auth-msg"></div>
            
            <form id="signup-form">
                <div class="form-group">
                    <label>Username</label>
                    <input type="text" id="signup-name" placeholder="johndoe" required>
                </div>
                <div class="form-group">
                    <label>Email Address</label>
                    <input type="email" id="signup-email" placeholder="you@example.com" required>
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <input type="password" id="signup-password" placeholder="••••••••" required>
                </div>
                <button type="submit" class="btn btn-primary">Sign up</button>
            </form>
            
            <div class="auth-switch">
                Already have an account? <a href="/login">Sign in</a>
            </div>
        </div>
    </div>
</div>

<script>
    if (localStorage.getItem('devconnect_token')) window.location.href = '/dashboard';

    document.getElementById('signup-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const msg = document.getElementById('signup-msg');
        msg.style.display = 'none';

        try {
            const res = await fetch('/api/auth/register', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    name: document.getElementById('signup-name').value,
                    email: document.getElementById('signup-email').value,
                    password: document.getElementById('signup-password').value
                })
            });
            const data = await res.json();
            
            if (res.ok) {
                msg.className = 'auth-msg success';
                msg.textContent = 'Account created! Redirecting...';
                msg.style.display = 'block';
                setTimeout(() => window.location.href = '/login', 1500);
            } else {
                msg.className = 'auth-msg error';
                msg.textContent = data.message || 'Signup failed';
                msg.style.display = 'block';
            }
        } catch (e) {
            msg.className = 'auth-msg error';
            msg.textContent = 'Server error';
            msg.style.display = 'block';
        }
    });
</script>

<%- include('partials/footer') %>